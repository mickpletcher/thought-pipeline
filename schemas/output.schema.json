{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/thought-pipeline/output.schema.json",
  "title": "Thought Pipeline Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "raw_idea",
    "captured_at",
    "source",
    "capture_id",
    "summary",
    "tags",
    "next_steps",
    "provider",
    "processed_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "raw_idea": {
      "type": "string",
      "minLength": 1
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "capture_id": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "provider": {
      "type": "string",
      "enum": [
        "local",
        "openai"
      ]
    },
    "processed_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
